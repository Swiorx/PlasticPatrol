# Copy this file to backend/.env and fill in your values
# cp backend/.env.example backend/.env

DATABASE_URL="postgresql://admin:admin123@localhost:5432/plasticpatrol"
SECRET_KEY="change-me-to-a-long-random-secret"

# Sentinel Hub / Copernicus Data Space credentials
# Get yours at: https://dataspace.copernicus.eu/
SH_CLIENT_ID="your-sentinel-hub-client-id"
SH_CLIENT_SECRET="your-sentinel-hub-client-secret"
SH_BASE_URL="https://sh.dataspace.copernicus.eu"

# Optional tuning (these have sane defaults if omitted)
# USE_MOCK_DATA=0
# USE_PRESET_LOCATIONS=true
# PRESET_LOCATION_SET=world_hotspots
# TARGET_RESOLUTION_METERS=10
# MIN_COMPONENT_PIXELS=12
# MAX_RELEVANT_POINTS=1200
